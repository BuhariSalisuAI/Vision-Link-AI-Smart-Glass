# .gitignore
# Vision-Link AI Smart Glass
# Files to ignore in Git

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
venv/
ENV/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Secrets and Config
.env
*.env
secrets/
config_local.py

# Logs
logs/
*.log

# Models (large files - use Git LFS or download links)
app/models/*.h5
app/models/*.pb
app/models/*.pkl
app/models/*.yml
app/models/*.weights

# Data
data/
*.csv
*.json
!docs/hausa_phrases.json

# OS
.DS_Store
Thumbs.db

# Test coverage
htmlcov/
.coverage
.pytest_cache/
